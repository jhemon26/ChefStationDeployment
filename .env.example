# ─── Database ────────────────────────────────────────────────────────────────
# Use a strong random password in production — never leave this as the default.
POSTGRES_USER=chefstation
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=chefstation

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# REQUIRED in production (min 32 chars). Server refuses to start without it.
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32
JWT_EXPIRES_IN=8h

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production this MUST include your Netlify URL only — no wildcards.
CORS_ORIGIN=http://localhost:3000

# ─── Rate limiting ────────────────────────────────────────────────────────────
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=2000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# ─── Super admin seed ─────────────────────────────────────────────────────────
# This account is created/synced on every server boot.
# Use a long random password (min 16 chars required in production).
# Change the username to something that is not guessable.
SEED_SUPER_ADMIN_USERNAME=CHANGE_ME@yourdomain.com
SEED_SUPER_ADMIN_PASSWORD=CHANGE_ME_min16chars_strongPassword!

# ─── Client (Vite build-time) ─────────────────────────────────────────────────
# Point this at your production API URL when deploying to Netlify.
VITE_API_URL=http://localhost:5001/api

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001
UPLOAD_DIR=./uploads
